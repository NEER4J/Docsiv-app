# Update these with your Supabase details from your project settings > API
# https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key

# Get your key from https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=your-gemini-api-key

# Optional: real-time presence (cursors, "X viewing"). Get secret from https://liveblocks.io
# Must start with sk_ — if missing or invalid, the editor works without presence.
# LIVEBLOCKS_SECRET_KEY=sk_your_liveblocks_secret

# Deck/presentation editor uses Slides.com (embed + Define API). No env required; users link or create decks on Slides.com.